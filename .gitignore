# =============================================
# JavaTetris HTML5 / Phaser 3 .gitignore
# =============================================

# Editor / IDE files
.vscode/
.idea/
*.sublime-*
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime / cache
.cache/
.tmp/
temp/

# Build / distribution (in case you ever add one later)
dist/
build/

# Dependency directories (even though you currently have none)
node_modules/
bower_components/

# Local environment / config
.env
.env.local

# Editor-specific
*.code-workspace